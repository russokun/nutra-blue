PORT=3001
ENVIRONMENT=development
CORS_ORIGIN=http://localhost:3000
INTERNAL_API_KEY=change-me-to-a-secure-random-string
ADMIN_EMAILS=admin@nutrablue.cl

# Solo para desarrollo local sin Supabase configurado. Se ignora automaticamente si ENVIRONMENT=production. NUNCA setear en produccion.
ALLOW_MOCK_AUTH=false

# Email (Resend) — set EMAIL_ENABLED=true to activate
EMAIL_ENABLED=false
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Nutra Blue <noreply@nutrablue.cl>

# Supabase Credentials (from your Supabase project settings)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Google Sheets Catalog Sync Configuration (published to web as CSV)
GOOGLE_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1v.../pub?output=csv


# AI Proxy Credentials
INTEGRATED_AI_API_URL=https://api.integrated-ai.com/v1
INTEGRATED_AI_API_KEY=your-ai-api-key
WEBSITE_ID=your-website-id
WEBSITE_DOMAIN=localhost:3000

# Payment Gateway Configuration
# Choose from: mock, flow, mercadopago, transbank
PAYMENT_PROVIDER=mock

# Flow Credentials
FLOW_API_URL=https://sandbox.flow.cl/api
FLOW_API_KEY=your-flow-api-key
FLOW_SECRET_KEY=your-flow-secret-key

# Mercado Pago Credentials
MERCADOPAGO_ACCESS_TOKEN=your-mp-access-token

# Transbank Webpay Credentials (leave empty to use Webpay Integration Sandbox by default)
WEBPAY_COMMERCE_CODE=597055555532
WEBPAY_API_KEY=

# Cloudflare R2 Credentials (Storage for Product Images & Media)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=nutrablue
R2_PUBLIC_DOMAIN=https://media.nutrablue.cl

