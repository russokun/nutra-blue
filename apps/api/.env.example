PORT=3001
# ENVIRONMENT decide cual set de credenciales se activa: "development" o "production".
# Todas las variables de abajo aceptan un sufijo _DEV / _PROD para tener ambos entornos
# en el mismo archivo (ej: SUPABASE_URL_DEV y SUPABASE_URL_PROD). Si no defines el sufijo,
# se usa el nombre plano tal cual (compatibilidad con un .env de un solo entorno).
ENVIRONMENT=development
INTERNAL_API_KEY=change-me-to-a-secure-random-string
ADMIN_EMAILS=admin@nutrablue.cl

# Solo aplica si ENVIRONMENT=development (se ignora automaticamente en produccion). NUNCA activar en produccion.
ALLOW_MOCK_AUTH=false

CORS_ORIGIN_DEV=http://localhost:3000
CORS_ORIGIN_PROD=https://nutrablue.cl

WEBSITE_DOMAIN_DEV=localhost:3000
WEBSITE_DOMAIN_PROD=nutrablue.cl

# Email (Resend) — set EMAIL_ENABLED=true para activar
EMAIL_ENABLED_DEV=false
EMAIL_ENABLED_PROD=true
RESEND_API_KEY_DEV=re_your_dev_resend_api_key
RESEND_API_KEY_PROD=re_your_prod_resend_api_key
EMAIL_FROM=Nutra Blue <noreply@nutrablue.cl>

# Supabase Credentials (desde los settings de tu proyecto Supabase)
SUPABASE_URL_DEV=https://your-dev-project.supabase.co
SUPABASE_KEY_DEV=your-dev-anon-key
SUPABASE_SERVICE_KEY_DEV=your-dev-service-role-key
SUPABASE_URL_PROD=https://your-prod-project.supabase.co
SUPABASE_KEY_PROD=your-prod-anon-key
SUPABASE_SERVICE_KEY_PROD=your-prod-service-role-key

# Google Sheets Catalog Sync Configuration (published to web as CSV)
GOOGLE_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1v.../pub?output=csv

# AI Proxy Credentials
INTEGRATED_AI_API_URL=https://api.integrated-ai.com/v1
INTEGRATED_AI_API_KEY=your-ai-api-key
WEBSITE_ID=your-website-id

# Payment Gateway Configuration
# Choose from: mock, flow, mercadopago, transbank
PAYMENT_PROVIDER_DEV=mock
PAYMENT_PROVIDER_PROD=transbank

# Flow Credentials
FLOW_API_URL_DEV=https://sandbox.flow.cl/api
FLOW_API_URL_PROD=https://www.flow.cl/api
FLOW_API_KEY_DEV=your-flow-sandbox-api-key
FLOW_SECRET_KEY_DEV=your-flow-sandbox-secret-key
FLOW_API_KEY_PROD=your-flow-live-api-key
FLOW_SECRET_KEY_PROD=your-flow-live-secret-key

# Mercado Pago Credentials
MERCADOPAGO_ACCESS_TOKEN_DEV=your-mp-test-access-token
MERCADOPAGO_ACCESS_TOKEN_PROD=your-mp-live-access-token

# Transbank Webpay Credentials (dejar vacio usa el sandbox de integracion de Webpay)
WEBPAY_COMMERCE_CODE_DEV=597055555532
WEBPAY_API_KEY_DEV=
WEBPAY_COMMERCE_CODE_PROD=your-real-commerce-code
WEBPAY_API_KEY_PROD=your-real-webpay-api-key

# Cloudflare R2 Credentials (Storage for Product Images & Media)
R2_ACCOUNT_ID_DEV=your_dev_cloudflare_account_id
R2_ACCESS_KEY_ID_DEV=your_dev_r2_access_key_id
R2_SECRET_ACCESS_KEY_DEV=your_dev_r2_secret_access_key
R2_BUCKET_NAME_DEV=nutrablue-dev
R2_PUBLIC_DOMAIN_DEV=https://media-dev.nutrablue.cl
R2_ACCOUNT_ID_PROD=your_prod_cloudflare_account_id
R2_ACCESS_KEY_ID_PROD=your_prod_r2_access_key_id
R2_SECRET_ACCESS_KEY_PROD=your_prod_r2_secret_access_key
R2_BUCKET_NAME_PROD=nutrablue
R2_PUBLIC_DOMAIN_PROD=https://media.nutrablue.cl
